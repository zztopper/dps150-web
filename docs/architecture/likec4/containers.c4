// Containers view — top-level containers inside the system.
// Fill in as the project grows.

specification {
  element container
  element database {
    style {
      shape storage
    }
  }
}

model {
  extend app {
    // Examples — replace with your own stack:
    //
    // container web 'Web Frontend' {
    //   technology 'React, TypeScript'
    // }
    // container api 'API Backend' {
    //   technology 'Go, REST'
    // }
    // database db 'Primary DB' {
    //   technology 'PostgreSQL 16'
    // }
    //
    // web -> api 'JSON/HTTPS'
    // api -> db 'SQL/TLS'
  }
}

views {
  view containers of app {
    title 'Containers'
    include *
    autoLayout
  }
}
