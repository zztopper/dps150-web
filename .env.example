# =============================================================================
# Boilerplate secrets / env. Скопируйте в .env и заполните своими значениями.
# .env должен быть в .gitignore (никогда не коммитить!)
# =============================================================================

# -----------------------------------------------------------------------------
# Issue tracker (выберите один — GitLab ИЛИ GitHub)
# -----------------------------------------------------------------------------
# ISSUE_PROVIDER принимает значения: gitlab | github
ISSUE_PROVIDER=gitlab

# --- GitLab ---
# Хост вашего GitLab (для self-hosted) или gitlab.com.
GITLAB_HOST=gitlab.example.com

# Группа/namespace и проект. Полный путь = "$GITLAB_GROUP/$GITLAB_PROJECT".
GITLAB_GROUP=applications
GITLAB_PROJECT=my-project

# Personal Access Token (PAT) с правами: api, read_repository, write_repository.
# Создаётся в: GitLab → Preferences → Access Tokens.
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# (Опционально) Userpass для базовой авторизации, если PAT не используется.
# GITLAB_USER=
# GITLAB_PASSWORD=

# --- GitHub ---
# Полный slug репо в формате owner/repo, например "myorg/my-project".
GITHUB_REPO=owner/my-project

# Personal Access Token (classic или fine-grained) с правами: repo, workflow.
# Создаётся в: GitHub → Settings → Developer settings → Personal access tokens.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# MCP серверы — переменные подставляются Claude Code в .mcp.json
# -----------------------------------------------------------------------------
# Полный URL до GitLab API (для self-hosted), используется gitlab MCP-сервером.
# Для gitlab.com можно оставить пустым — сервер использует значение по умолчанию.
GITLAB_HOST_URL=https://gitlab.example.com/api/v4

# Опционально: ключ для Context7 hosted (приватная документация).
# CONTEXT7_API_KEY=

# Опционально: путь к persistent memory MCP-сервера.
# По умолчанию .mcp.json указывает .claude/memory/mcp-memory.jsonl.
# MEMORY_FILE_PATH=.claude/memory/mcp-memory.jsonl

# -----------------------------------------------------------------------------
# Опционально: HashiCorp Vault (для централизованных секретов)
# -----------------------------------------------------------------------------
# VAULT_ADDR=https://vault.example.com
# VAULT_TOKEN=

# -----------------------------------------------------------------------------
# Опционально: Anthropic API key (если запускаете claude код-агентов из CI)
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Локальная разработка приложения (адаптируйте под свой стек)
# -----------------------------------------------------------------------------
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USER=
# DATABASE_PASSWORD=
# DATABASE_NAME=
# REDIS_HOST=localhost
# REDIS_PORT=6379
# JWT_SECRET=
# LOG_LEVEL=debug
