# CODEOWNERS — auto-assign reviewers for paths.
# Скопируйте в корень репо: cp templates/CODEOWNERS.example CODEOWNERS
# (или .github/CODEOWNERS для GitHub).
#
# Формат: <pattern> <owner1> <owner2> ...
# Owner может быть @username, @org/team, или email.

# Default — все файлы
*                                @org/maintainers

# Backend
/backend/                        @org/backend-team
/backend/migrations/             @org/dba @org/backend-team

# Frontend
/frontend/                       @org/frontend-team

# Infrastructure / CI
/deploy/                         @org/devops
/.gitlab-ci.yml                  @org/devops
/.github/workflows/              @org/devops
/Dockerfile*                     @org/devops

# Docs / процесс
/docs/architecture/              @org/architects
/docs/adr-workflow.md            @org/architects
/CLAUDE.md                       @org/maintainers
/.claude/                        @org/maintainers

# Security-чувствительное
/backend/internal/auth/          @org/security @org/backend-team
*/migrations/*                   @org/dba
