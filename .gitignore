# Секреты
.env
.env.local
.env.*.local

# Claude Code локальные настройки
.claude/settings.local.json

# Serena кэш
.serena/cache/

# MCP memory store (содержит граф знаний, может быть большим/приватным)
.claude/memory/mcp-memory.jsonl

# Boilerplate update backups (созданы scripts/boilerplate-update.sh)
.boilerplate-update/
.boilerplate-backup/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp

# Build artifacts
backend/bin/
frontend/dist/
# Embedded frontend bundle (copied by `make embed-frontend`); only the
# .gitkeep placeholder is committed so go:embed compiles without a build.
backend/internal/webui/dist/*
!backend/internal/webui/dist/.gitkeep
frontend/node_modules/
frontend/coverage/
*.db

# Claude worktrees
.claude/worktrees/
tokens-section-empty.png
/*.png

# Playwright MCP browser artifacts
.playwright-mcp/
*.png
